		margin-bottom: 1.5rem;
	}

	.section-title h2 {
		margin-bottom: 0.4rem;
	}

	.section-title p {
		margin: 0;
		color: #6b7280;
	}

	.gallery-grid,
	.inline-gallery {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.inline-gallery {
		margin-top: 1.5rem;
	}

	figure {
		margin: 0;
		background: #fffaf2;
		border: 1px solid #e5dfd3;
		border-radius: 22px;
		overflow: hidden;
		box-shadow: 0 12px 30px rgba(31, 41, 51, 0.06);
	}

	figure img {
		display: block;
		width: 100%;
		height: 280px;
		object-fit: contain;
		background: #ffffff;
