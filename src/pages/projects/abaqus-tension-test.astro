		color: #8a5a28;
		font-weight: 700;
	}

	.back-link:hover {
		color: #111827;
	}

	.eyebrow {
		margin: 0 0 1rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-size: 0.85rem;
		font-weight: 700;
		color: #8a5a28;
	}

