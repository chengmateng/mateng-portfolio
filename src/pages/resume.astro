---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Resume | Mateng Cheng</title>
		<meta
			name="description"
			content="Resume of Mateng Cheng, Civil / Structural Engineer with experience in structural analysis, finite element modeling, engineering documentation, and infrastructure resilience."
		/>
	</head>

	<body>
		<header class="site-header">
			<nav>
				<a href="/" class="logo">Mateng Cheng</a>

				<div class="nav-links">
					<a href="/">Home</a>
					<a href="/#projects">Projects</a>
					<a href="/#contact">Contact</a>
				</div>
			</nav>
		</header>

		<main id="top">
			<section class="resume-hero">
				<a class="back-link" href="/">← Back to Home</a>

				<p class="eyebrow">Resume · Civil / Structural Engineer</p>

				<h1>Resume</h1>

				<p class="hero-text">
					Ph.D. candidate in Civil Engineering with experience in structural analysis,
					finite element modeling, engineering documentation, field engineering, and
					infrastructure resilience.
				</p>

				<div class="resume-actions">
					<a class="button primary" href="/Mateng_Cheng_Resume.pdf" target="_blank">
						Open PDF
					</a>
					<a class="button" href="/Mateng_Cheng_Resume.pdf" download>
						Download Resume
					</a>
					<a class="button" href="/#contact">
						Contact Me
					</a>
				</div>
			</section>

			<section class="section">
				<div class="resume-card desktop-pdf">
					<iframe
						src="/Mateng_Cheng_Resume.pdf#zoom=page-width"
						title="Mateng Cheng Resume PDF"
					></iframe>
				</div>

				<div class="mobile-pdf-card">
					<p class="mobile-pdf-label">Resume PDF</p>
					<h2>Mateng Cheng Resume</h2>
					<p>
						For the best mobile viewing experience, open the PDF in a new tab or download it.
					</p>

					<div class="mobile-pdf-actions">
						<a class="button primary" href="/Mateng_Cheng_Resume.pdf" target="_blank">
							Open PDF
						</a>
						<a class="button" href="/Mateng_Cheng_Resume.pdf" download>
							Download
						</a>
					</div>
				</div>

				<p class="pdf-note">
					If the PDF preview does not load, use the Open PDF or Download Resume button above.
				</p>
			</section>
		</main>

		<a class="back-to-top" href="#top" aria-label="Back to top">↑</a>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		color: #1f2933;
		background: #f7f4ef;
		line-height: 1.6;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: rgba(247, 244, 239, 0.92);
		border-bottom: 1px solid #e5dfd3;
		backdrop-filter: blur(10px);
	}

	nav {
		width: 100%;
		max-width: 1360px;
		margin: 0 auto;
		padding: 1rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
	}

	.logo {
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #111827;
		white-space: nowrap;
	}

	.nav-links {
		margin-left: auto;
		display: flex;
		gap: 0.75rem;
		font-size: 0.95rem;
		font-weight: 700;
		color: #4b5563;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links a {
		padding: 0.45rem 0.85rem;
		border: 1px solid #c9bba6;
		border-radius: 999px;
		font-weight: 700;
		background: #fffaf2;
		color: #8a5a28;
		white-space: nowrap;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.nav-links a:hover {
		background: #1f2933;
		border-color: #1f2933;
		color: #ffffff;
		transform: translateY(-1px);
	}

	main {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 1.5rem 4rem;
	}

	.resume-hero {
		padding: 5.5rem 0 3.5rem;
		max-width: 900px;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: #8a5a28;
		font-weight: 700;
	}

	.back-link:hover {
		color: #111827;
	}

	.eyebrow {
		margin: 0 0 1rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-size: 0.85rem;
		font-weight: 700;
		color: #8a5a28;
	}

	h1 {
		margin: 0;
		max-width: 1050px;
		font-size: clamp(2.8rem, 5.2vw, 4.4rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
		color: #111827;
	}

	.hero-text {
		max-width: 820px;
		margin: 1.4rem 0 0;
		font-size: 1.18rem;
		color: #4b5563;
	}

	.resume-actions {
		display: flex;
		gap: 0.85rem;
		margin-top: 2rem;
		flex-wrap: wrap;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1.1rem;
		border: 1px solid #c9bba6;
		border-radius: 999px;
		font-weight: 700;
		background: #fffaf2;
		color: #8a5a28;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			background 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.button:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 20px rgba(31, 41, 51, 0.08);
		background: #1f2933;
		border-color: #1f2933;
		color: #ffffff;
	}

	.button.primary {
		background: #1f2933;
		color: white;
		border-color: #1f2933;
	}

	.section {
		padding: 3.5rem 0;
		border-top: 1px solid #e5dfd3;
	}

	.resume-card {
		background: #fffaf2;
		border: 1px solid #e5dfd3;
		border-radius: 24px;
		padding: 1rem;
		box-shadow: 0 18px 42px rgba(31, 41, 51, 0.09);
		overflow: hidden;
	}

	iframe {
		display: block;
		width: 100%;
		height: 1050px;
		border: 0;
		border-radius: 16px;
		background: #ffffff;
	}

	.mobile-pdf-card {
		display: none;
		background: #fffaf2;
		border: 1px solid #e5dfd3;
		border-radius: 24px;
		padding: 1.3rem;
		box-shadow: 0 18px 42px rgba(31, 41, 51, 0.09);
	}

	.mobile-pdf-label {
		margin: 0 0 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.75rem;
		font-weight: 800;
		color: #8a5a28;
	}

	.mobile-pdf-card h2 {
		margin: 0 0 0.7rem;
		font-size: 1.6rem;
		letter-spacing: -0.03em;
		color: #111827;
	}

	.mobile-pdf-card p {
		margin: 0;
		color: #4b5563;
	}

	.mobile-pdf-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1.2rem;
	}

	.pdf-note {
		margin: 1rem 0 0;
		color: #6b7280;
		font-size: 0.95rem;
	}

	.back-to-top {
		position: fixed;
		right: 1.5rem;
		bottom: 1.5rem;
		width: 46px;
		height: 46px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		border: 1px solid #c9bba6;
		background: #fffaf2;
		color: #8a5a28;
		font-size: 1.4rem;
		font-weight: 800;
		box-shadow: 0 10px 24px rgba(31, 41, 51, 0.12);
		z-index: 20;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.back-to-top:hover {
		background: #1f2933;
		color: #ffffff;
		transform: translateY(-2px);
		box-shadow: 0 14px 30px rgba(31, 41, 51, 0.18);
	}

	@media (max-width: 1024px) {
		nav {
			align-items: flex-start;
			gap: 0.9rem;
			flex-direction: column;
			padding: 1rem 1.25rem;
		}

		.nav-links {
			display: flex;
			flex-wrap: wrap;
			justify-content: flex-start;
			gap: 0.55rem;
			width: 100%;
		}

		.nav-links a {
			padding: 0.38rem 0.65rem;
			font-size: 0.82rem;
			line-height: 1.1;
		}

		.resume-hero {
			padding: 4.5rem 0 3rem;
		}

		.desktop-pdf {
			display: none;
		}

		.mobile-pdf-card {
			display: block;
		}

		.pdf-note {
			display: none;
		}

		.back-to-top {
			right: 1rem;
			bottom: 1rem;
			width: 42px;
			height: 42px;
			font-size: 1.2rem;
		}
	}

	@media (max-width: 420px) {
		.nav-links {
			gap: 0.5rem;
		}

		.nav-links a {
			padding: 0.35rem 0.58rem;
			font-size: 0.78rem;
		}

		.logo {
			font-size: 0.95rem;
		}

		.mobile-pdf-card {
			padding: 1.1rem;
			border-radius: 18px;
		}
	}
</style>